# ============================================================
# VELOCITY ENGINE - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to GitHub!
# ============================================================

# --- Alpaca API ---
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_TRADING_MODE=paper
# Options: 'paper' or 'live'
# Paper uses: https://paper-api.alpaca.markets
# Live uses:  https://api.alpaca.markets

# --- Live Trading Safety Gate ---
# You MUST set this to 'true' to enable live trading
# This prevents accidental live trades
LIVE_TRADING_CONFIRMED=false

# --- Database ---
DATABASE_URL=postgresql://velocity:velocity_pass@localhost:5432/velocity_engine
# For Docker: postgresql://velocity:velocity_pass@postgres:5432/velocity_engine

# --- Trading Parameters ---
BASE_CAPITAL=100000
MAX_POSITIONS=4
RISK_PER_TRADE=0.02
MAX_POSITION_PCT=0.25
DRAWDOWN_THRESHOLD=0.15

# --- Scan Schedule ---
SCAN_INTERVAL_MINUTES=3
MONITOR_INTERVAL_SECONDS=60
VIX_UPDATE_MINUTES=5
EQUITY_RECONCILE_MINUTES=30
BROKER_SYNC_MINUTES=15

# --- Logging ---
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# --- API Server (optional) ---
API_HOST=0.0.0.0
API_PORT=8000
